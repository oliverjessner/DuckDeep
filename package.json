{
    "name": "duck-deep",
    "version": "0.2.0",
    "private": false,
    "description": "Duck Deep browser strategy board game as a vanilla Web Component and optional React component.",
    "type": "module",
    "main": "./dist/duck-deep.js",
    "module": "./dist/duck-deep.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/duck-deep.js"
        },
        "./element": {
            "types": "./dist/element.d.ts",
            "import": "./dist/duck-deep.element.js"
        },
        "./style.css": {
            "types": "./dist/style.css.d.ts",
            "import": "./dist/duck-deep.css",
            "default": "./dist/duck-deep.css"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "sideEffects": [
        "**/*.css",
        "./dist/duck-deep.element.js"
    ],
    "scripts": {
        "dev": "vite",
        "build": "npm run build:lib",
        "build:app": "tsc && vite build --outDir dist-app",
        "build:lib": "rm -rf dist && vite build --config vite.lib.config.ts && vite build --config vite.element.config.ts && cp src/styles.css dist/duck-deep.css && cp src/style.css.d.ts dist/style.css.d.ts && tsc -p tsconfig.lib.json",
        "build:all": "npm run build:app && npm run build:lib",
        "pack:local": "npm pack",
        "prepack": "npm run build:lib",
        "preview": "vite preview --outDir dist-app",
        "test": "vitest run"
    },
    "peerDependencies": {
        "react": "^18.3.0 || ^19.0.0",
        "react-dom": "^18.3.0 || ^19.0.0"
    },
    "peerDependenciesMeta": {
        "react": {
            "optional": true
        },
        "react-dom": {
            "optional": true
        }
    },
    "devDependencies": {
        "@testing-library/react": "^16.3.2",
        "@vitejs/plugin-react": "^6.0.3",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "jsdom": "^29.1.1",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.10"
    }
}
